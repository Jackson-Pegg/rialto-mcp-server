# .env — environment variables for local development
# In production, these would be injected by the deployment environment (e.g. AWS Secrets Manager,
# Azure Key Vault, or a Kubernetes secret) and never committed to source control.
#
# Database credentials (replace with real values locally; never commit real values)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rialto_loans
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
#
# MCP server config
# MCP_SERVER_HOST=0.0.0.0
# MCP_SERVER_PORT=8000
